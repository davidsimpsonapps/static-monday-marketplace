{% if app %}
  {% set _origin = site.origin if (site and site.origin) else '' %}
  {% set _vendor = vendors | findVendorById(app.marketplace_developer_id) %}
  {% set _rating = ratings | findRatingById(app.app_id) %}
  {% set _appReviews = reviews[app.app_id] %}
  {% set _productUrl = _origin ~ '/apps/' ~ app.id ~ '/' %}
  {% set _vendorUrl = _origin ~ '/vendors/' ~ (_vendor.id if _vendor else '') ~ '/' %}
  {% set _isArchived = (not app.marketplace_category_ids) or (app.marketplace_category_ids.length === 0) %}

  {# Collect image-only gallery assets to avoid trailing-comma issues when videos are present #}
  {% set _screenshotUrls = [] %}
  {% if app.gallery_assets and app.gallery_assets.length > 0 %}
    {% for asset in app.gallery_assets %}
      {% if asset.type != 'video' %}
        {% set _screenshotUrls = _screenshotUrls | concat([asset.url]) %}
      {% endif %}
    {% endfor %}
  {% endif %}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "@id": {{ (_productUrl ~ '#software') | dump | safe }},
        "name": {{ (app.name or '') | dump | safe }},
        "description": {{ (((app.name or '') ~ ' (app for monday.com). ' ~ (app.short_description or '')) | trim) | dump | safe }},
        "url": {{ _productUrl | dump | safe }},
        "installUrl": {{ ('https://auth.monday.com/marketplace_app_from_anywhere?app_id=' ~ app.id) | dump | safe }},
        "operatingSystem": "Any",
        "applicationCategory": "BusinessApplication",
        "isAccessibleForFree": {% if app.plans %}false{% else %}true{% endif %},
        "image": {{ (app.logo_url or '') | dump | safe }},
        {% if app.created_at %}"datePublished": {{ app.created_at | dump | safe }},{% endif %}
        {% if app.updated_at %}"dateModified": {{ app.updated_at | dump | safe }},{% endif %}
        {% if _screenshotUrls.length > 0 %}
        "screenshot": [
          {% for url in _screenshotUrls %}{{ url | dump | safe }}{% if not loop.last %},{% endif %}{% endfor %}
        ],
        {% endif %}
        {% if _rating %}
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ _rating.rating or 0 }}",
          "reviewCount": {{ _rating.count or 0 }},
          "bestRating": "5",
          "worstRating": "1"
        },
        {% endif %}
        {% set _approvedReviews = _appReviews | approvedReviews %}
        {% if _approvedReviews and _approvedReviews.length > 0 %}
        "review": [
          {% for review in _approvedReviews %}{
            "@type": "Review",
            "author": {
              "@type": "Person",
              "name": {{ (review.reviewerNameInitials or 'Anonymous') | dump | safe }}
            },
            "reviewRating": {
              "@type": "Rating",
              "ratingValue": "{{ review.rating or 0 }}",
              "bestRating": "5",
              "worstRating": "1"
            },
            "reviewBody": {{ (review.comment or '') | dump | safe }}{% if review.commentedAt %},
            "datePublished": {{ review.commentedAt | dump | safe }}{% endif %}
          }{% if not loop.last %},{% endif %}{% endfor %}
        ],
        {% endif %}
        {% if app.plans and app.plans.length > 0 %}
        "offers": [
          {% for plan in app.plans | latestVersionPlans %}{% if plan.prices and plan.prices.monthly %}{
            "@type": "Offer",
            "name": {{ (plan.name or '') | dump | safe }},
            "price": "{{ plan.prices.monthly }}",
            "priceCurrency": "USD",
            "priceSpecification": {
              "@type": "UnitPriceSpecification",
              "price": "{{ plan.prices.monthly }}",
              "priceCurrency": "USD",
              "billingDuration": 1,
              "billingIncrement": 1,
              "unitText": "MONTH"
            }
          }{% if not loop.last %},{% endif %}{% endif %}{% endfor %}
        ],
        {% endif %}
        "publisher": {
          "@type": "Organization",
          "name": {{ ((_vendor and _vendor.name) or 'Unknown') | dump | safe }},
          "url": {{ ((_vendor and _vendor.website) or '') | dump | safe }}
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home",    "item": {{ _origin | dump | safe }}},
          {% if _isArchived %}
          {"@type": "ListItem", "position": 2, "name": "Archive", "item": {{ (_origin ~ '/apps/archive/') | dump | safe }}},
          {"@type": "ListItem", "position": 3, "name": {{ (app.name or '') | dump | safe }}, "item": {{ _productUrl | dump | safe }}}
          {% else %}
          {"@type": "ListItem", "position": 2, "name": "Vendors", "item": {{ (_origin ~ '/vendors/') | dump | safe }}},
          {% if _vendor %}
          {"@type": "ListItem", "position": 3, "name": {{ (_vendor.name or '') | dump | safe }}, "item": {{ _vendorUrl | dump | safe }}},
          {% endif %}
          {"@type": "ListItem", "position": {% if _vendor %}4{% else %}3{% endif %}, "name": {{ (app.name or '') | dump | safe }}, "item": {{ _productUrl | dump | safe }}}
          {% endif %}
        ]
      }
    ]
  }
  </script>
{% endif %}
