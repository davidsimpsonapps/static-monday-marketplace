<h1 class="text-lg md:text-2xl font-semibold mb-4">monday.com service status</h1>

{% set ongoingCount = 0 %}
{% for incident in incidents %}{% if not incident.end %}{% set ongoingCount = ongoingCount + 1 %}{% endif %}{% endfor %}

<nav class="tabs">
  <a data-match="exact" href="/status/">Service status</a>
  <a data-match="include" href="/status/incidents/">Incidents <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">{{ ongoingCount }}</span></a>
  <a data-match="include" href="/status/infrastructure/">Infrastructure</a>
</nav>


<h2 class="mt-0">Incident history</h2>


<p>This page is a collective memory of incidents which may not be recorded elsewhere.</p>

<hr>

<div class="incidents max-w-screen-md">
{% for incident in incidents %}
    <div class="my-6">
        <div class="incident-heading">
            {{ incident.start }}
            {% if incident.end %}
                 - {{ incident.end }}
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Resolved
                </span>
            {% else %}
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                    Ongoing • {{ incident.start | daysSince }} days
                </span>
            {% endif %}
        </div>
        <h3 class="font-semibold my-2">{{ incident.title | safe }}</h3>
        <h4 class="incident-heading">Description</h4>
        <div>
            {{ incident.description | safe }}
        </div>
        {% if incident.resolution %}
          <h4 class="incident-heading">Resolution</h4>
          {{ incident.resolution | safe }}
        {% endif %}
    </div>
{% endfor %} 